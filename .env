# ── Database ───────────────────────────────────────────────────────────────────
SPENDIFY_DB=sqlite:///ledger.db

# ── Taxonomy ──────────────────────────────────────────────────────────────────
TAXONOMY_PATH=taxonomy.yaml

# ── PII sanitization ──────────────────────────────────────────────────────────
# Comma-separated list of owner names to redact with <OWNER>
OWNER_NAMES=Mario Rossi,M. Rossi

# ── LLM backend selection ─────────────────────────────────────────────────────
# Options: local_ollama | openai | claude
LLM_BACKEND=local_ollama

# ── Ollama (local — default) ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# ── OpenAI (opt-in remote) ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Claude / Anthropic (opt-in remote) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-haiku-20241022
