# ══════════════════════════════════════════════════════════════════════════════
# Spendify — configurazione ambiente
# Copia questo file in .env e compila i valori.
# Il file .env NON va mai committato (è in .gitignore).
#
# NOTA: backend LLM, API key, modelli e tutte le preferenze utente
# si configurano DALL'APP nella pagina ⚙️ Impostazioni — non qui.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────────────────
# Percorso del database SQLite.
# Installazione locale: lascia il default (file nella cartella del progetto).
# Docker: viene sovrascritto da docker-compose.yml → non modificare.
SPENDIFY_DB=sqlite:///ledger.db

# ── Tassonomia ─────────────────────────────────────────────────────────────────
TAXONOMY_PATH=taxonomy.yaml

# ── llama.cpp profile (solo se usi docker compose --profile llama-cpp) ─────────
# Nome del file GGUF nella cartella ./models/
# LLAMA_MODEL=gemma-3-4b-it-Q4_K_M.gguf
